pipeline {

    agent any

    tools{
        maven 'maven'
    }

    environment {

        IMAGE_NAME = "mardan112/jenkinsimage:latest"
    }


    stages {


        stage('Checkout Code') {

            steps {

                checkout scm

            }

        }



        stage('Maven Build') {

            steps {

                sh '''

                mvn clean package -DskipTests

                '''

            }

        }



        stage('Docker Build') {

            steps {

                sh """

                docker build \
                -t newanime .

                """

            }

        }



        stage('Docker Login and Push') {


            steps {


                withCredentials([usernamePassword(

                    credentialsId: 'dockerhub',

                    usernameVariable: 'DOCKER_USER',

                    passwordVariable: 'DOCKER_PASSWORD'

                )]) {


                    sh """
                        docker tag newanime:latest dockerhub-mardan112/jenkinsimage:latest
                        docker images
                        docker push mardan112/jenkinsimage:latest
                    """

                }

            }

        }



        stage('Cleanup Docker System') {


            steps {


                sh '''

                docker logout


                docker image prune -f


                docker container prune -f


                rm -rf target/


                '''

            }

        }

    }



    post {


        always {


            cleanWs()

        }

    }

}